{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roller Admin",
  "version": "0.5.0",
  "identifier": "software.meps.roller",
  "build": {
    "beforeDevCommand": "npm --prefix ../roller-admin run start:desktop",
    "devUrl": "http://localhost:4201",
    "beforeBuildCommand": "npm --prefix ../roller-admin run build:desktop",
    "frontendDist": "../../roller-admin/dist/roller-admin/browser"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "dmg",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/roller-backend"
    ]
  }
}
