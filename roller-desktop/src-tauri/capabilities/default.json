{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window: core APIs plus permission to spawn the bundled NestJS sidecar from the frontend (the Rust side spawns it directly and does not need this; kept for completeness).",
  "windows": ["main", "planning-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/roller-backend",
          "sidecar": true
        }
      ]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "mailto:*" },
        { "url": "tel:*" }
      ]
    },
    "dialog:allow-save",
    "fs:allow-write-file",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://roller-admin.booringsoftware.com/**" }]
    }
  ]
}
